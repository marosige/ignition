#!/bin/bash

# Define the path to the docker-compose.yml file
COMPOSE_FILE="$HOME/docker/docker-compose.yml"
COMPOSE_CMD="docker-compose -f $COMPOSE_FILE"

# Function to get local IP address
get_local_ip() {
    # Use ip or ifconfig command to get the local IP address
    ip addr show eth0 | grep -oP 'inet \K[\d.]+'
}

# Function to show Docker Compose information
show_info() {
    echo "Showing Docker Compose info..."
    $COMPOSE_CMD config
}

# Function to show Docker Compose status (ps)
show_status() {
    echo "Showing Docker Compose status..."
    $COMPOSE_CMD ps
}

# Function to start Docker Compose in detached mode
start_compose() {
    echo "Starting Docker Compose in detached mode..."
    $COMPOSE_CMD up -d
}

# Function to stop Docker Compose
stop_compose() {
    echo "Stopping Docker Compose..."
    $COMPOSE_CMD down
}

# Function to show bookmark URLs for services
show_bookmarks() {
    echo "Showing Docker Compose service URLs (Bookmarks)..."

    # Get the local IP address
    local_ip=$(get_local_ip)

    # Parse the docker-compose.yml file to get the services and their port mappings
    services=$(yq e '.services | keys' $COMPOSE_FILE)

    # Loop through the services and show URLs for each one that has port mappings
    for service in $(echo "$services" | jq -r '.[]'); do
        ports=$($COMPOSE_CMD port $service)
        if [ -n "$ports" ]; then
            echo "$service: http://$local_ip:$ports"
        else
            echo "$service has no ports exposed."
        fi
    done
}

# Print usage if no arguments are passed
usage() {
    echo "Usage: $0 {info|status|start|stop|bookmark}"
    exit 1
}

# Check the passed argument and call the appropriate function
case "$1" in
    info)
        show_info
        ;;
    status)
        show_status
        ;;
    start)
        start_compose
        ;;
    stop)
        stop_compose
        ;;
    bookmark)
        show_bookmarks
        ;;
    *)
        usage
        ;;
esac